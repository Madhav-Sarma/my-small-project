{
  "id": "notion-connector",
  "name": "Notion Connector",
  "version": "1.0.0",
  "type": "connector",
  "description": "Two-way integration with Notion workspaces",
  "author": "aios-team",
  "icon": "book-open",
  "authType": "OAUTH2",
  "baseUrl": "https://api.notion.com/v1",
  "actions": [
    { "id": "create-page", "name": "Create Page", "method": "POST", "path": "/pages" },
    { "id": "get-page", "name": "Get Page", "method": "GET", "path": "/pages/{page_id}" },
    { "id": "search", "name": "Search", "method": "POST", "path": "/search" }
  ],
  "events": [
    { "id": "page-updated", "name": "Page Updated", "type": "webhook" }
  ]
}
