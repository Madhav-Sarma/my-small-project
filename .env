# ──────────────────────────────────────
# AIOS Platform — Environment Variables
# ──────────────────────────────────────

# Database
DATABASE_URL=postgresql://aios:aios@localhost:5432/aios_platform
REDIS_URL=redis://localhost:6379

# Auth (Clerk)
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# AI Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
REPLICATE_API_KEY=
HUGGINGFACE_API_KEY=

# Stripe Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Platform
NODE_ENV=development
PORT=4000
AI_GATEWAY_PORT=4100
AGENT_RUNNER_PORT=4200
WORKFLOW_ENGINE_PORT=4300
WEB_PORT=3000

# Security
JWT_SECRET=change-me-in-production
ENCRYPTION_KEY=change-me-in-production
